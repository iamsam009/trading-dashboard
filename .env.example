# ─── Database ──────────────────────────────────────────
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=trading_pass
POSTGRES_DB=trading_db
DATABASE_URL=postgresql+asyncpg://trading_user:trading_pass@postgres:5432/trading_db

# ─── Redis ─────────────────────────────────────────────
REDIS_PASSWORD=redis_pass
REDIS_URL=redis://:redis_pass@redis:6379/0

# ─── Shark Trading API ────────────────────────────────
SHARK_API_KEY=your_shark_api_key_here
SHARK_API_SECRET=your_shark_api_secret_here
SHARK_BASE_URL=https://api.shark.in/v1
SHARK_WS_URL=wss://ws.shark.in/v1
SHARK_SSL_VERIFY=true

# ─── Security ──────────────────────────────────────────
# Generate with: python generate_secret_key.py
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Environment ───────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=debug

# ─── Frontend (Next.js Public) ─────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws